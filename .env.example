# AI Gateway — powers the content agent
AI_GATEWAY_API_KEY=


# Telegram — bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# GitHub — repo access for the agent to commit content
GITHUB_TOKEN=
GITHUB_OWNER=DiegoJohnsonL
GITHUB_REPO=ai-blog-template
GITHUB_BRANCH=main

# PostgreSQL — chat state, users, whitelist
DATABASE_URL=postgresql://user:password@localhost:5432/ai_blog

# Site — production URL for the agent to build blog links
SITE_URL=https://ai-blog-template.vercel.app

# Allowed Telegram user IDs (comma-separated) for team auth
ALLOWED_TELEGRAM_USERS=
